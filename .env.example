# Web Push (alertas de venda no dashboard) — gere com: npx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
# Opcional: mailto ou URL de contato (RFC 8292)
WEB_PUSH_CONTACT=mailto:suporte@seudominio.com
